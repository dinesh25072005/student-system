# ============================================
# STUDENT AUTOMATION SYSTEM - ENVIRONMENT VARS
# ============================================

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/studentDB?retryWrites=true&w=majority

# JWT Secret - make this a long random string
JWT_SECRET=your_super_secret_jwt_key_change_this_123456

# JWT Expiry
JWT_EXPIRE=7d

# Server Port
PORT=5000

# ---- EMAIL CONFIG (Gmail SMTP) ----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=yourschool@gmail.com
EMAIL_PASS=your_16_char_app_password

# School name shown in messages
SCHOOL_NAME=Sunrise Public School

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ---- WHATSAPP ----
# NO API KEY NEEDED! Uses whatsapp-web.js (free)
# Just scan the QR code from /api/whatsapp/qr after starting the server
# Uses your school's own WhatsApp number - 100% FREE forever
